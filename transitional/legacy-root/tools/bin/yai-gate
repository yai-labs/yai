#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$ROOT/tools/dev/resolve-governance-root.sh"
INFRA_ROOT_DEFAULT="$(cd "$ROOT/.." && pwd)/infra"
INFRA_ROOT="${YAI_INFRA_ROOT:-$INFRA_ROOT_DEFAULT}"
TARGET="$INFRA_ROOT/tools/bin/yai-gate"
GOVERNANCE_ROOT="$(yai_resolve_governance_root "$ROOT" || true)"

if [[ -x "$TARGET" ]]; then
  YAI_CORE_ROOT="$ROOT" \
  YAI_GOVERNANCE_ROOT="${GOVERNANCE_ROOT:-}" \
  YAI_GOVERNANCE_COMPAT_ROOT="${GOVERNANCE_ROOT:-}" \
  YAI_SPECS_ROOT="${GOVERNANCE_ROOT:-}" \
  exec "$TARGET" "$@"
fi

echo "Hard cutover: use infra canonical tool for yai-gate" >&2
echo "Missing target: $TARGET" >&2
exit 2
