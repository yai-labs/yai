#!/usr/bin/env bash
set -euo pipefail

ICON="${YAI_WS_PROMPT_ICON:-◉}"
HOME_DIR="${HOME:-}"

if [[ "${1:-}" == "--help" ]]; then
  cat <<'EOF'
usage: yai-ws-token [--icon <icon>] [--ascii]

Prints a compact workspace prompt token using current directory workspace scope:
  <icon> <workspace_alias>

Resolution order:
  1) YAI_ACTIVE_WORKSPACE env override (if valid workspace manifest exists)
  2) current cwd mapped to workspace root_path from ~/.yai/run/*/manifest.json
     (deepest root wins)

Output is empty when cwd is outside any known workspace root.
EOF
  exit 0
fi

if [[ "${1:-}" == "--icon" && -n "${2:-}" ]]; then
  ICON="${2}"
fi

if [[ "${1:-}" == "--ascii" || "${2:-}" == "--ascii" ]]; then
  ICON="${YAI_WS_PROMPT_ICON_ASCII:-*}"
fi

if [[ -z "$HOME_DIR" ]]; then
  exit 0
fi

python3 - "$HOME_DIR" "$ICON" <<'PY'
import json
import os
import pathlib
import re
import sys

home_dir = sys.argv[1]
icon = sys.argv[2]
run_dir = pathlib.Path(home_dir) / ".yai" / "run"
cwd = pathlib.Path(os.getcwd()).resolve()
ws_env = os.environ.get("YAI_ACTIVE_WORKSPACE", "").strip()


def valid_ws_id(v: str) -> bool:
    return bool(v and re.fullmatch(r"[A-Za-z0-9._-]+", v))


def load_manifest_for_ws(ws_id: str):
    p = run_dir / ws_id / "manifest.json"
    if not p.is_file():
        return None
    try:
        payload = json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return None
    root_raw = str(payload.get("root_path", "")).strip()
    if not root_raw:
        return None
    try:
        root = pathlib.Path(root_raw).resolve()
    except Exception:
        return None
    alias = str(payload.get("workspace_alias", "")).strip() or ws_id
    return (ws_id, alias, root)


if valid_ws_id(ws_env):
    m = load_manifest_for_ws(ws_env)
    if m is not None:
        _, alias, root = m
        try:
            cwd.relative_to(root)
            print(f"{icon} {alias}")
            sys.exit(0)
        except Exception:
            pass

if not run_dir.is_dir():
    sys.exit(0)

best = None
best_len = -1
for entry in run_dir.iterdir():
    if not entry.is_dir():
        continue
    ws_id = entry.name
    if not valid_ws_id(ws_id):
        continue
    m = load_manifest_for_ws(ws_id)
    if m is None:
        continue
    _, alias, root = m
    try:
        cwd.relative_to(root)
    except Exception:
        continue
    n = len(str(root))
    if n >= best_len:
        best_len = n
        best = alias

if best:
    print(f"{icon} {best}")
PY
