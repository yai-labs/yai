#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
PID_FILE="${HOME}/.yai/run/runtime.pid"
INGRESS_SOCK="${YAI_RUNTIME_INGRESS:-$HOME/.yai/run/control.sock}"

if [[ -f "$PID_FILE" ]]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$PID" ]] && kill -0 "$PID" 2>/dev/null; then
    kill "$PID" || true
    sleep 1
  fi
  rm -f "$PID_FILE"
fi

if [[ -S "$INGRESS_SOCK" ]]; then
  rm -f "$INGRESS_SOCK"
fi

if [[ -f "${ROOT}/Makefile" ]]; then
  (cd "${ROOT}" && make clean)
fi

if [[ -d "${HOME}/.yai/artifacts" ]]; then
  find "${HOME}/.yai/artifacts" -type d \( -name build -o -name target -o -name dist \) -prune -exec rm -rf {} +
fi

echo "OK: purge complete"
