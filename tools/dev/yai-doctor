#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$ROOT/tools/dev/resolve-yai-bin.sh"
BIN="$(yai_resolve_bin "$ROOT" || true)"
INGRESS_SOCK="${YAI_RUNTIME_INGRESS:-$HOME/.yai/run/control.sock}"
PID_FILE="${HOME}/.yai/run/runtime.pid"

echo "=== YAI Doctor"
echo "repo: ${ROOT}"

echo "=== Binaries"
[[ -x "$ROOT/build/bin/yai" ]] && echo "OK: $ROOT/build/bin/yai" || echo "MISSING: $ROOT/build/bin/yai"

echo "=== yai in PATH"
if [[ -n "$BIN" ]]; then
  echo "OK: $(command -v yai)"
  "$BIN" --help >/dev/null || true
else
  echo "MISSING: yai not found in PATH"
fi

echo "=== Runtime ingress"
if [[ -S "$INGRESS_SOCK" ]]; then
  echo "OK: socket $INGRESS_SOCK"
else
  echo "MISSING: socket $INGRESS_SOCK"
fi

echo "=== Runtime pidfile"
if [[ -f "$PID_FILE" ]]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$PID" ]] && kill -0 "$PID" 2>/dev/null; then
    echo "OK: pidfile $PID_FILE (pid=$PID alive)"
  else
    echo "STALE: pidfile $PID_FILE"
  fi
else
  echo "MISSING: pidfile $PID_FILE"
fi

echo "=== Duplicate yai binaries"
if [[ -d "${HOME}/.yai/artifacts" ]]; then
  find "${HOME}/.yai/artifacts" -type f -name "yai" -perm -111 -print || true
else
  echo "SKIP: legacy artifacts directory not present"
fi

echo "OK: doctor complete"
