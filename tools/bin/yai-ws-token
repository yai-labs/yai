#!/usr/bin/env bash
set -euo pipefail

ICON="${YAI_WS_PROMPT_ICON:-◉}"
HOME_DIR="${HOME:-}"
BIND_FILE="${HOME_DIR}/.yai/session/active_workspace.json"

if [[ "${1:-}" == "--help" ]]; then
  cat <<'EOF'
usage: yai-ws-token [--icon <icon>] [--ascii]

Prints a compact workspace prompt token using active session binding:
  <icon> <workspace_alias>

Output is empty when no active/valid workspace binding is present.
EOF
  exit 0
fi

if [[ "${1:-}" == "--icon" && -n "${2:-}" ]]; then
  ICON="${2}"
fi

if [[ "${1:-}" == "--ascii" || "${2:-}" == "--ascii" ]]; then
  ICON="${YAI_WS_PROMPT_ICON_ASCII:-*}"
fi

if [[ -z "$HOME_DIR" || ! -f "$BIND_FILE" ]]; then
  exit 0
fi

python3 - "$BIND_FILE" "$ICON" <<'PY'
import json
import pathlib
import re
import sys

bind_path = pathlib.Path(sys.argv[1])
icon = sys.argv[2]

try:
    payload = json.loads(bind_path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

ws_id = str(payload.get("workspace_id", "")).strip()
ws_alias = str(payload.get("workspace_alias", "")).strip() or ws_id

if not ws_id or not re.fullmatch(r"[A-Za-z0-9._-]+", ws_id):
    sys.exit(0)

manifest = pathlib.Path.home() / ".yai" / "run" / ws_id / "manifest.json"
if not manifest.exists():
    sys.exit(0)

print(f"{icon} {ws_alias}")
PY
