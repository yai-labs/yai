#!/usr/bin/env bash
set -euo pipefail

ICON="${YAI_WS_PROMPT_ICON:-◉}"
HOME_DIR="${HOME:-}"

if [[ "${1:-}" == "--help" ]]; then
  cat <<'EOF'
usage: yai-ws-token [--icon <icon>] [--ascii]

Prints a compact workspace prompt token using active session binding:
  <icon> <workspace_alias>

Resolution order:
  1) per-TTY binding (~/.yai/session/by-tty/<tty>.json) when available
  2) session-global binding (~/.yai/session/active_workspace.json) only when no TTY
     is available (non-interactive/scripted contexts)

Output is empty when no active/valid workspace binding is present for the current session.
EOF
  exit 0
fi

if [[ "${1:-}" == "--icon" && -n "${2:-}" ]]; then
  ICON="${2}"
fi

if [[ "${1:-}" == "--ascii" || "${2:-}" == "--ascii" ]]; then
  ICON="${YAI_WS_PROMPT_ICON_ASCII:-*}"
fi

if [[ -z "$HOME_DIR" ]]; then
  exit 0
fi

python3 - "$HOME_DIR" "$ICON" <<'PY'
import json
import os
import pathlib
import re
import sys

home_dir = sys.argv[1]
icon = sys.argv[2]
session_dir = pathlib.Path(home_dir) / ".yai" / "session"
bind_scope = os.environ.get("YAI_WS_BIND_SCOPE", "").strip().lower()

def tty_tag() -> str:
    override = os.environ.get("YAI_WS_TTY_TAG_OVERRIDE", "").strip()
    if override:
        return re.sub(r"[^A-Za-z0-9]", "_", override) or "unknown_tty"
    for fd in (0, 1, 2):
        try:
            tty = os.ttyname(fd)
            if tty:
                return re.sub(r"[^A-Za-z0-9]", "_", tty) or "unknown_tty"
        except OSError:
            continue
    return ""

tag = tty_tag()
if bind_scope in ("global", "shared"):
    bind_path = session_dir / "active_workspace.json"
elif tag:
    # Interactive mode: keep binding session-scoped to current terminal.
    bind_path = session_dir / "by-tty" / f"{tag}.json"
else:
    # Non-interactive mode: fallback to global binding for scripts/tests.
    bind_path = session_dir / "active_workspace.json"

if not bind_path.is_file():
    sys.exit(0)

try:
    payload = json.loads(bind_path.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

ws_id = str(payload.get("workspace_id", "")).strip()
ws_alias = str(payload.get("workspace_alias", "")).strip() or ws_id

if not ws_id or not re.fullmatch(r"[A-Za-z0-9._-]+", ws_id):
    sys.exit(0)

print(f"{icon} {ws_alias}")
PY
