#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$ROOT/tools/dev/resolve-law-compat.sh"
INFRA_ROOT_DEFAULT="$(cd "$ROOT/.." && pwd)/infra"
INFRA_ROOT="${YAI_INFRA_ROOT:-$INFRA_ROOT_DEFAULT}"
TARGET="$INFRA_ROOT/tools/release/check_pins.sh"
LAW_COMPAT_ROOT="$(yai_resolve_law_compat_root "$ROOT" || true)"

if [[ -x "$TARGET" ]]; then
  YAI_CORE_ROOT="$ROOT" \
  YAI_LAW_COMPAT_ROOT="${LAW_COMPAT_ROOT:-}" \
  YAI_SPECS_ROOT="${LAW_COMPAT_ROOT:-}" \
  exec "$TARGET" "$@"
fi

echo "Hard cutover: use infra canonical tool for yai-check-pins" >&2
echo "Missing target: $TARGET" >&2
exit 2
